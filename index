let current = 0;
let known = 0;
let unknown = 0;
let answered = new Array(words.length).fill(null);
let isFlipped = false;

function render() {
  const w = words[current];
  document.getElementById('front-word').textContent = w.word;
  document.getElementById('back-meaning').textContent = w.meaning;
  document.getElementById('back-example').textContent = w.example;
  document.getElementById('counter').textContent = `${current + 1} / ${words.length}`;

  // reset flip
  const card = document.getElementById('card');
  card.classList.remove('flipped');
  isFlipped = false;

  updateStats();
}

function flipCard() {
  const card = document.getElementById('card');
  isFlipped = !isFlipped;
  card.classList.toggle('flipped', isFlipped);
}

function markCard(isKnown) {
  if (answered[current] === null) {
    answered[current] = isKnown;
    if (isKnown) known++; else unknown++;
  } else {
    // update if changed
    const prev = answered[current];
    if (prev !== isKnown) {
      answered[current] = isKnown;
      if (isKnown) { known++; unknown--; } else { known--; unknown++; }
    }
  }
  updateStats();

  const answeredCount = answered.filter(a => a !== null).length;
  if (answeredCount === words.length) {
    showResult();
    return;
  }

  // move to next unanswered or just next
  let next = (current + 1) % words.length;
  current = next;
  render();
}

function nextCard() {
  current = (current + 1) % words.length;
  render();
}

function prevCard() {
  current = (current - 1 + words.length) % words.length;
  render();
}

function updateStats() {
  document.getElementById('known-count').textContent = known;
  document.getElementById('unknown-count').textContent = unknown;
  const done = answered.filter(a => a !== null).length;
  document.getElementById('progress-fill').style.width = `${(done / words.length) * 100}%`;
}

function showResult() {
  document.getElementById('scene').style.display = 'none';
  document.querySelector('.btn-row').style.display = 'none';
  document.querySelector('.nav-row').style.display = 'none';
  document.querySelector('.flip-hint').style.display = 'none';
  document.getElementById('result-known').textContent = known;
  document.getElementById('result-unknown').textContent = unknown;
  document.getElementById('result-screen').classList.add('show');
}

function restart() {
  current = 0; known = 0; unknown = 0;
  answered = new Array(words.length).fill(null);
  document.getElementById('scene').style.display = '';
  document.querySelector('.btn-row').style.display = '';
  document.querySelector('.nav-row').style.display = '';
  document.querySelector('.flip-hint').style.display = '';
  document.getElementById('result-screen').classList.remove('show');
  render();
}

// keyboard shortcuts
document.addEventListener('keydown', e => {
  if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); flipCard(); }
  if (e.key === 'ArrowRight') nextCard();
  if (e.key === 'ArrowLeft') prevCard();
  if (e.key === 'o' || e.key === 'O') markCard(true);
  if (e.key === 'x' || e.key === 'X') markCard(false);
});

render();
</script>
